---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Vault 007. 2026 Aston Martin Vantage Coupe. 656hp. 2,519 miles. Jet Black over Onyx Haircalf. Asking $199,007. Full factory warranty. Private sale, North Shore Chicago.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://vault007.com/hero_poster.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={`https://vault007.com${Astro.url.pathname}`} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://vault007.com/hero_poster.jpg" />

    <!-- Canonical -->
    <link rel="canonical" href={`https://vault007.com${Astro.url.pathname}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Montserrat:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <script src="../scripts/main.js"></script>

    <!-- Site-wide background music. Persists across page navigations. -->
    <audio id="siteMusic" autoplay muted loop playsinline preload="auto" data-base={base}>
      <source src={`${base}audio/hero_music.mp3`} type="audio/mpeg" />
    </audio>

    <button id="siteMusicBtn" class="hero-music-btn" aria-label="Toggle background music" title="Toggle music">
      <svg id="musicIconOn" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
        <path d="M9 3v10.55A4 4 0 1 0 11 17V7h4V3H9z"/>
      </svg>
      <svg id="musicIconOff" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="display:none">
        <path d="M9 3v10.55A4 4 0 1 0 11 17V7h4V3" opacity="0.3"/>
        <line x1="3" y1="3" x2="21" y2="21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <script>
    (function initSiteMusic() {
      const audio   = document.getElementById('siteMusic');
      const btn     = document.getElementById('siteMusicBtn');
      const iconOn  = document.getElementById('musicIconOn');
      const iconOff = document.getElementById('musicIconOff');
      if (!audio || !btn) return;

      const TARGET_VOL = 0.32;
      const FADE_MS    = 1500;

      // Visual state helpers
      function showOnIcon() {
        if (iconOn)  iconOn.style.display  = '';
        if (iconOff) iconOff.style.display = 'none';
        btn.style.opacity = '1';
      }
      function showOffIcon() {
        if (iconOn)  iconOn.style.display  = 'none';
        if (iconOff) iconOff.style.display = '';
        btn.style.opacity = '0.45';
      }

      // Smooth fade from current volume to a target over duration ms
      let fadeRaf = 0;
      function fadeTo(target, duration) {
        cancelAnimationFrame(fadeRaf);
        const start    = performance.now();
        const startVol = audio.volume;
        const delta    = target - startVol;
        const step = (now) => {
          const p = Math.min(1, (now - start) / duration);
          audio.volume = Math.max(0, Math.min(1, startVol + delta * p));
          if (p < 1) fadeRaf = requestAnimationFrame(step);
        };
        fadeRaf = requestAnimationFrame(step);
      }

      // Initial state: muted autoplay attempt (browsers permit muted autoplay)
      audio.muted  = true;
      audio.volume = 0;
      showOffIcon();
      audio.play().catch(() => { /* swallow — toggle button still works */ });

      // First user interaction unmutes with a smooth fade-in.
      // If user already used the toggle, dataset.userInteracted is set and we skip.
      function autoUnmute() {
        if (audio.dataset.userInteracted === '1') return cleanupAutoUnmute();
        audio.dataset.userInteracted = '1';
        audio.muted = false;
        // Make sure it's actually playing (mobile sometimes refuses muted autoplay too)
        audio.play().catch(() => {});
        fadeTo(TARGET_VOL, FADE_MS);
        showOnIcon();
        cleanupAutoUnmute();
      }
      const evs = ['click', 'scroll', 'keydown', 'touchstart', 'mousemove'];
      function cleanupAutoUnmute() {
        evs.forEach(e => document.removeEventListener(e, autoUnmute));
      }
      evs.forEach(e => document.addEventListener(e, autoUnmute, { once: true, passive: true }));

      // Toggle button — mute / unmute manually.
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        // Mark that user has explicitly interacted; suppress further auto behavior
        audio.dataset.userInteracted = '1';
        cleanupAutoUnmute();

        if (audio.muted || audio.volume === 0) {
          audio.muted = false;
          if (audio.paused) audio.play().catch(() => {});
          fadeTo(TARGET_VOL, 600);
          showOnIcon();
        } else {
          fadeTo(0, 400);
          // After fade, hard mute so it doesn't sneak back up
          setTimeout(() => { audio.muted = true; }, 450);
          showOffIcon();
        }
      });
    })();

    </script>
  </body>
</html>
