---

<Layout title="Gallery — 2026 Aston Martin Vantage" description="26 photos, 60+ video clips — exterior, interior, engine, and showroom inspection. Jet Black, 656hp, $199,007. Private sale Chicagoland IL.">

  <nav class="nav scrolled" role="navigation" aria-label="Main navigation">
    <a href={b} class="nav-logo">V<span>antage</span></a>
    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links">
      <li><a href={b}>Home</a></li>
      <li><a href={`${b}gallery`}>Gallery</a></li>
      <li><a href={`${b}specs`}>Specifications</a></li>
      <li><a href={`${b}contact`} class="nav-cta">Inquire</a></li>
    </ul>
  </nav>

  <div class="page-hero">
    <img src={`${b}photos/IMG_8190.JPG`} alt="2026 Aston Martin Vantage" loading="eager" />
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <p class="label">Visual Overview</p>
      <h1>Gallery</h1>
      <p class="gallery-hero-sub">26 photographs &middot; 60+ films</p>
    </div>
  </div>

  <!-- ═══ EXTERIOR FILMS ═══ -->
  <section class="gallery-section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="label">Film</p>
        <h2>Exterior</h2>
        <p class="gallery-section-sub">39 clips &mdash; golden hour, dusk, and night</p>
      </div>
      <div class="video-grid gallery-video-grid fade-in">
        {exteriorVids.map((v) => (
          <div class="video-thumb" data-src={v.src} tabindex="0" role="button">
            <img src={v.thumb} alt={v.label} loading="lazy" />
            <div class="video-play-btn" aria-hidden="true"><Fragment set:html={playIcon} /></div>
            <span class="video-label">{v.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ UNDER THE HOOD ═══ -->
  <section class="gallery-section gallery-section--alt">
    <div class="container">
      <div class="section-header fade-in">
        <p class="label">Film</p>
        <h2>Under the Hood</h2>
        <p class="gallery-section-sub">4.0L twin-turbo V8 &mdash; 656 horsepower</p>
      </div>
      <div class="video-grid gallery-video-grid gallery-video-grid--sm fade-in">
        {engineVids.map((v) => (
          <div class="video-thumb" data-src={v.src} tabindex="0" role="button">
            <img src={v.thumb} alt={v.label} loading="lazy" />
            <div class="video-play-btn" aria-hidden="true"><Fragment set:html={playIcon} /></div>
            <span class="video-label">{v.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ THE COCKPIT ═══ -->
  <section class="gallery-section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="label">Film</p>
        <h2>The Cockpit</h2>
        <p class="gallery-section-sub">Haircalf leather, AMR Lime stitching, 10.25" display</p>
      </div>
      <div class="video-grid gallery-video-grid fade-in">
        {cockpitVids.map((v) => (
          <div class="video-thumb" data-src={v.src} tabindex="0" role="button">
            <img src={v.thumb} alt={v.label} loading="lazy" />
            <div class="video-play-btn" aria-hidden="true"><Fragment set:html={playIcon} /></div>
            <span class="video-label">{v.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ THE INSPECTION ═══ -->
  <section class="gallery-section gallery-section--alt">
    <div class="container">
      <div class="section-header fade-in">
        <p class="label">Film</p>
        <h2>The Inspection</h2>
        <p class="gallery-section-sub">Condition walkaround &mdash; showroom lighting, zero excuses</p>
      </div>
      <div class="video-grid gallery-video-grid fade-in">
        {inspectionVids.map((v) => (
          <div class="video-thumb" data-src={v.src} tabindex="0" role="button">
            <img src={v.thumb} alt={v.label} loading="lazy" />
            <div class="video-play-btn" aria-hidden="true"><Fragment set:html={playIcon} /></div>
            <span class="video-label">{v.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ PHOTOGRAPHY ═══ -->
  <section class="photo-section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="label">Photography</p>
        <h2>26 Photos</h2>
      </div>

      <div class="gallery-filters fade-in" role="tablist" aria-label="Filter photos by category">
        <button class="filter-btn active" data-filter="all" role="tab" aria-selected="true">All <span class="filter-count"></span></button>
        <button class="filter-btn" data-filter="day" role="tab" aria-selected="false">Day <span class="filter-count"></span></button>
        <button class="filter-btn" data-filter="night" role="tab" aria-selected="false">Night <span class="filter-count"></span></button>
        <button class="filter-btn" data-filter="engine" role="tab" aria-selected="false">Engine <span class="filter-count"></span></button>
      </div>

      <div class="photo-grid" id="photoGrid">
        {photos.map((p) => (
          <div class="photo-item fade-in" data-category={p.cat} tabindex="0" role="button">
            <img
              src={`${b}thumbs/${p.name}.JPG`}
              data-full={`${b}photos/${p.name}.JPG`}
              alt={p.alt}
              loading="lazy"
            />
          </div>
        ))}
      </div>

      <p class="gallery-empty" style="display:none;text-align:center;color:var(--text-dim);padding:3rem 0;font-size:.82rem;letter-spacing:.15em;text-transform:uppercase;">No photos in this category</p>
    </div>
  </section>

  <footer>
    <div class="container">
      <p class="footer-logo">Vantage</p>
      <p>2026 Aston Martin Vantage Coupe &mdash; VIN: SCFSMGFW8TGN10773</p>
      <p style="margin-top:0.5rem;">Chicagoland, IL &nbsp;&middot;&nbsp; <a href={`${b}contact`} style="color:var(--lime);">Contact for Inquiries</a></p>
    </div>
  </footer>

  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Photo lightbox">
    <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
    <div class="lightbox-inner">
      <img class="lightbox-img" src="" alt="" />
    </div>
    <button class="lightbox-prev" aria-label="Previous photo">&#8592;</button>
    <button class="lightbox-next" aria-label="Next photo">&#8594;</button>
    <div class="lightbox-counter" aria-live="polite"></div>
    <div class="lightbox-hint" aria-hidden="true">&#8592; &#8594; navigate &nbsp;&nbsp; Esc close</div>
  </div>

  <div id="videoModal" class="video-modal" role="dialog" aria-modal="true" aria-label="Video player">
    <button class="video-modal-close" aria-label="Close video">&times;</button>
    <div class="video-modal-inner">
      <video controls playsinline></video>
    </div>
  </div>

  <audio id="classicalAudio" loop preload="none">
    <source src={`${b}audio/classical.mp3`} type="audio/mpeg" />
  </audio>

  <button id="musicToggle" aria-label="Toggle classical music" title="Toggle classical music"
    style="position:fixed;bottom:2rem;right:2rem;z-index:9999;width:3rem;height:3rem;border-radius:50%;border:1px solid rgba(255,255,255,0.25);background:rgba(10,10,10,0.85);backdrop-filter:blur(8px);cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.2rem;transition:border-color .2s,background .2s;"
    onmouseover="this.style.borderColor='#b5cc4a';this.style.background='rgba(20,20,20,0.95)'"
    onmouseout="this.style.borderColor='rgba(255,255,255,0.25)';this.style.background='rgba(10,10,10,0.85)'">
    &#9835;
  </button>

  <script>
  (function () {
    const audio = document.getElementById('classicalAudio') as HTMLAudioElement;
    const btn   = document.getElementById('musicToggle') as HTMLButtonElement;
    const modal = document.getElementById('videoModal');
    let playing = false;

    function startMusic() {
      audio.play().then(() => { playing = true; btn.style.color = '#b5cc4a'; }).catch(() => {});
    }
    function stopMusic() {
      audio.pause(); playing = false; btn.style.color = '#fff';
    }

    btn.addEventListener('click', () => playing ? stopMusic() : startMusic());

    if (modal) {
      new MutationObserver(() => {
        if (modal.classList.contains('open')) { if (!playing) startMusic(); }
        else { stopMusic(); }
      }).observe(modal, { attributes: true, attributeFilter: ['class'] });
    }
  })();
  </script>

</Layout>
