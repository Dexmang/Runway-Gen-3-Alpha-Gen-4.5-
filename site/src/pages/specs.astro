---
import Layout from '../layouts/Layout.astro';
const b = import.meta.env.BASE_URL;
---

<Layout title="Specifications — 2026 Aston Martin Vantage" description="Full specifications and pricing for the 2026 Aston Martin Vantage Coupe. 656hp, $199,007, full factory warranty.">

  <nav class="nav scrolled" role="navigation" aria-label="Main navigation">
    <a href={b} class="nav-logo">V<span>antage</span></a>
    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links">
      <li><a href={b}>Home</a></li>
      <li><a href={`${b}gallery`}>Gallery</a></li>
      <li><a href={`${b}specs`}>Specifications</a></li>
      <li><a href={`${b}contact`} class="nav-cta">Inquire</a></li>
    </ul>
  </nav>

  <div class="page-hero">
    <img src={`${b}photos/IMG_8173.JPG`} alt="2026 Aston Martin Vantage specifications" loading="eager" />
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <p class="label">Complete Details</p>
      <h1>Specifications</h1>
    </div>
  </div>

  <section style="background:var(--bg);">
    <div class="container">
      <div class="specs-layout">
        <aside class="specs-sidebar">
          <ul class="specs-nav" role="list">
            <li><a href="#overview">Overview</a></li>
            <li><a href="#performance">Performance</a></li>
            <li><a href="#exterior">Exterior</a></li>
            <li><a href="#interior">Interior</a></li>
            <li><a href="#technology">Technology</a></li>
            <li><a href="#safety">Safety</a></li>
            <li><a href="#warranty">Warranty</a></li>
            <li><a href="#pricing">Pricing</a></li>
          </ul>
        </aside>
        <div class="specs-content">

          <div id="overview" class="spec-section fade-in">
            <h3>Overview</h3>
            <table class="spec-table">
              <tr><td>Year / Model</td><td>2026 Aston Martin Vantage Coupe</td></tr>
              <tr><td>VIN</td><td>SCFSMGFW8TGN10773</td></tr>
              <tr><td>Engine Number</td><td>17785030013021</td></tr>
              <tr><td>Mileage</td><td>~2,519 miles</td></tr>
              <tr><td>Title</td><td>Clean — in hand</td></tr>
              <tr><td>Seller</td><td>Original owner, private sale</td></tr>
              <tr><td>Location</td><td>Chicagoland, Illinois</td></tr>
              <tr><td>Original Dealer</td><td>Glenview Luxury Imports, Glenview, IL</td></tr>
            </table>
          </div>

          <div id="performance" class="spec-section fade-in">
            <h3>Performance</h3>
            <table class="spec-table">
              <tr><td>Engine</td><td>4.0L Twin-Turbocharged V8</td></tr>
              <tr><td>Output</td><td>656 hp / 590 lb-ft torque</td></tr>
              <tr><td>Transmission</td><td>8-speed automatic (rear-mid mounted)</td></tr>
              <tr><td>Drivetrain</td><td>Rear-wheel drive</td></tr>
              <tr><td>Differential</td><td>Electronic rear differential with Dynamic Torque Vectoring</td></tr>
              <tr><td>Propshaft</td><td>Carbon fiber, via alloy torque tube</td></tr>
              <tr><td>Drive Modes</td><td>Sport, Sport+, Track, Wet, Individual</td></tr>
              <tr><td>Traction Systems</td><td>DSC, TC, PTC</td></tr>
            </table>
          </div>

          <div id="exterior" class="spec-section fade-in">
            <h3>Exterior</h3>
            <table class="spec-table">
              <tr><td>Color</td><td>Jet Black</td></tr>
              <tr><td>Roof</td><td>Gloss Black panel</td></tr>
              <tr><td>Accents</td><td>AMR Lime (splitter, side sills, diffuser)</td></tr>
              <tr><td>Trim Pack</td><td>Satin Black exterior</td></tr>
              <tr><td>Wheels</td><td>21" forged satin black</td></tr>
              <tr><td>Brake Calipers</td><td>Yellow</td></tr>
              <tr><td>Tail Lamps</td><td>Smoked</td></tr>
              <tr><td>Grille Vanes</td><td>Black</td></tr>
              <tr><td>Wings Badge</td><td>Black</td></tr>
              <tr><td>Mirrors</td><td>Power-folding, heated</td></tr>
            </table>
          </div>

          <div id="interior" class="spec-section fade-in">
            <h3>Interior</h3>
            <table class="spec-table">
              <tr><td>Upholstery</td><td>Onyx Black Haircalf Leather (RB981)</td></tr>
              <tr><td>Seats</td><td>12-way power-adjustable, heated, 3-position memory</td></tr>
              <tr><td>Steering Column</td><td>Power-adjustable tilt/telescoping</td></tr>
              <tr><td>Interior Mirror</td><td>Auto-dimming</td></tr>
              <tr><td>Ambient Lighting</td><td>Included</td></tr>
            </table>
          </div>

          <div id="technology" class="spec-section fade-in">
            <h3>Technology</h3>
            <table class="spec-table">
              <tr><td>Center Display</td><td>10.25" TFT touchscreen</td></tr>
              <tr><td>Driver Display</td><td>10.25" TFT instrument cluster</td></tr>
              <tr><td>Apple CarPlay</td><td>Wireless</td></tr>
              <tr><td>Phone Charging</td><td>Wireless</td></tr>
              <tr><td>Audio</td><td>Bluetooth, satellite radio (1-year trial)</td></tr>
              <tr><td>Camera System</td><td>360-degree with front &amp; rear parking sensors</td></tr>
              <tr><td>Adaptive Cruise Control</td><td>Included</td></tr>
              <tr><td>Rain-Sensing Wipers</td><td>Included</td></tr>
            </table>
          </div>

          <div id="safety" class="spec-section fade-in">
            <h3>Safety</h3>
            <ul class="spec-list">
              <li>Dual-stage driver &amp; passenger front airbags</li>
              <li>Seat-mounted side-impact airbags</li>
              <li>Curtain side-impact airbags</li>
              <li>Lane Keep Assist (LKA)</li>
              <li>Autonomous Emergency Braking (AEB)</li>
              <li>Dynamic Stability Control (DSC)</li>
              <li>Traction Control (TC)</li>
              <li>Positive Traction Control (PTC)</li>
            </ul>
          </div>

          <div id="warranty" class="spec-section fade-in">
            <h3>Warranty</h3>
            <table class="spec-table">
              <tr><td>Coverage</td><td>Aston Martin factory warranty</td></tr>
              <tr><td>Duration</td><td>3 years, unlimited mileage</td></tr>
              <tr><td>Roadside Assistance</td><td>24-hour included</td></tr>
              <tr><td>Transfer</td><td>Transfers to new owner at no cost</td></tr>
              <tr><td>Port of Entry</td><td>Baltimore, MD</td></tr>
            </table>
          </div>

          <div id="pricing" class="spec-section fade-in">
            <h3>Pricing</h3>
            <div class="pricing-table">
              <div class="pricing-row"><span class="label-left">Base MSRP</span><span class="amount">$191,000</span></div>
              <div class="pricing-row"><span class="label-left">Factory Options</span><span class="amount">$21,100</span></div>
              <div class="pricing-row"><span class="label-left">Import Costs</span><span class="amount">$6,700</span></div>
              <div class="pricing-row"><span class="label-left">Transportation &amp; Handling</span><span class="amount">$3,500</span></div>
              <div class="pricing-row total"><span class="label-left">Total Original MSRP</span><span class="amount">$222,800</span></div>
              <div class="pricing-row asking"><span class="label-left">Asking Price</span><span class="amount">$199,007</span></div>
              <div class="pricing-row savings"><span class="label-left">Savings vs. original MSRP</span><span class="amount">$23,793 below sticker</span></div>
            </div>
            <p style="margin-top:1.5rem;font-size:0.8rem;color:var(--text-dim);">Original window sticker included. Serious inquiries only — proof of funds required.</p>
            <a href={`${b}contact`} class="btn btn-primary" style="margin-top:1.5rem;">Inquire Now</a>
          </div>

        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p class="footer-logo">Vantage</p>
      <p>2026 Aston Martin Vantage Coupe &mdash; VIN: SCFSMGFW8TGN10773</p>
      <p style="margin-top:0.5rem;">Chicagoland, IL &nbsp;&middot;&nbsp; <a href={`${b}contact`} style="color:var(--lime);">Contact for Inquiries</a></p>
    </div>
  </footer>

</Layout>
