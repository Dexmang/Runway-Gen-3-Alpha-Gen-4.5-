---
import Layout from '../layouts/Layout.astro';
const b = import.meta.env.BASE_URL;
---

<Layout title="2026 Aston Martin Vantage — Private Sale" description="2026 Aston Martin Vantage Coupe. 656hp. 4,350 miles. Jet Black over Onyx Haircalf. $199,500. Full factory warranty. Private sale, Chicagoland.">

  <nav class="nav" role="navigation" aria-label="Main navigation">
    <a href={b} class="nav-logo">V<span>antage</span></a>
    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links">
      <li><a href={b}>Home</a></li>
      <li><a href={`${b}gallery`}>Gallery</a></li>
      <li><a href={`${b}specs`}>Specifications</a></li>
      <li><a href={`${b}contact`} class="nav-cta">Inquire</a></li>
    </ul>
  </nav>

  <section class="hero" aria-label="Hero">
    <div class="hero-video-wrap">
      <video autoplay muted loop playsinline poster={`${b}hero_poster.jpg`} aria-hidden="true">
        <source src={`${b}videos/outside/IMG_8121.mp4`} type="video/mp4" />
      </video>
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="label">Private Sale &mdash; Original Owner</p>
      <h1 class="hero-title">2026 Aston Martin<br />Vantage Coupe</h1>
      <p class="hero-sub">656 HP &nbsp;&middot;&nbsp; 4,350 Miles &nbsp;&middot;&nbsp; $199,500 &nbsp;&middot;&nbsp; Full Factory Warranty</p>
      <div class="hero-actions">
        <a href={`${b}gallery`} class="btn btn-primary">View Gallery</a>
        <a href={`${b}contact`} class="btn btn-outline">Inquire</a>
      </div>
    </div>
  </section>

  <div class="stats-bar" aria-label="Key figures">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item fade-in">
          <div class="stat-value">656<span>hp</span></div>
          <div class="stat-label">Twin-Turbo V8</div>
        </div>
        <div class="stat-item fade-in fade-in-delay-1">
          <div class="stat-value">4,350</div>
          <div class="stat-label">Miles on Odometer</div>
        </div>
        <div class="stat-item fade-in fade-in-delay-2">
          <div class="stat-value">$199.5<span>k</span></div>
          <div class="stat-label">Asking Price</div>
        </div>
      </div>
    </div>
  </div>

  <section class="overview">
    <div class="container">
      <div class="overview-grid">
        <div class="overview-text fade-in">
          <p class="label">Why This Car</p>
          <h2>The New-Generation Vantage</h2>
          <p>This is the completely redesigned Vantage — launched for 2025 with a <strong>155hp increase</strong> over the outgoing model, a new interior, and a chassis that reviewers have called the best-driving Aston Martin in a decade.</p>
          <p>Jet Black over Onyx Black Haircalf Leather with AMR Lime accents is a striking, tasteful spec. At <strong>$199,500</strong>, this represents a $23,300 saving over the original sticker on an essentially unworn car.</p>
          <p>Original owner. Clean title in hand. <strong>3-year unlimited-mileage factory warranty</strong> transfers to the new owner at no cost.</p>
          <a href={`${b}specs`} class="btn btn-outline" style="margin-top:1rem;">Full Specifications</a>
        </div>
        <div class="overview-image fade-in fade-in-delay-1">
          <img src={`${b}photos/IMG_8136.JPG`} alt="2026 Aston Martin Vantage — Jet Black, front three-quarter view" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="preview-grid-section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="label">Gallery Preview</p>
        <h2>Jet Black &amp; AMR Lime</h2>
      </div>
      <div class="preview-grid fade-in">
        <div class="preview-grid-wrap"><img src={`${b}photos/IMG_8137.JPG`} alt="Aston Martin Vantage badge and grille" loading="lazy" /></div>
        <div class="preview-grid-wrap"><img src={`${b}photos/IMG_8167.JPG`} alt="4.0L twin-turbo V8 engine bay" loading="lazy" /></div>
        <div class="preview-grid-wrap"><img src={`${b}photos/IMG_8190.JPG`} alt="Aston Martin Vantage at dusk" loading="lazy" /></div>
        <div class="preview-grid-wrap"><img src={`${b}photos/IMG_8196.JPG`} alt="Aston Martin Vantage headlights on" loading="lazy" /></div>
      </div>
      <div class="text-center fade-in">
        <a href={`${b}gallery`} class="btn btn-primary">View Full Gallery</a>
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p class="footer-logo">Vantage</p>
      <p>2026 Aston Martin Vantage Coupe &mdash; VIN: SCFSMGFW8TGN10773</p>
      <p style="margin-top:0.5rem;">Chicagoland, IL &nbsp;&middot;&nbsp; Private Sale &nbsp;&middot;&nbsp; <a href={`${b}contact`} style="color:var(--lime);">Contact for Inquiries</a></p>
    </div>
  </footer>

  <!-- Hero Background Music -->
  <audio id="heroMusic" loop preload="auto">
    <source src={`${b}audio/hero_music.mp3`} type="audio/mpeg" />
  </audio>

  <button id="heroMusicBtn" class="hero-music-btn" aria-label="Toggle background music" title="Toggle music">
    <svg id="musicIconOn" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
      <path d="M9 3v10.55A4 4 0 1 0 11 17V7h4V3H9z"/>
    </svg>
    <svg id="musicIconOff" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="display:none">
      <path d="M9 3v10.55A4 4 0 1 0 11 17V7h4V3H9z" opacity="0.3"/>
      <line x1="3" y1="3" x2="21" y2="21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>

  <script>
  (function () {
    const audio   = document.getElementById('heroMusic') as HTMLAudioElement;
    const btn     = document.getElementById('heroMusicBtn') as HTMLButtonElement;
    const iconOn  = document.getElementById('musicIconOn') as SVGElement;
    const iconOff = document.getElementById('musicIconOff') as SVGElement;
    let   started = false;
    let   muted   = false;

    audio.volume = 0;

    function fadeIn() {
      let v = 0;
      const tick = setInterval(() => {
        v = Math.min(v + 0.02, 0.32);
        audio.volume = v;
        if (v >= 0.32) clearInterval(tick);
      }, 80);
    }

    function startMusic() {
      if (started) return;
      started = true;
      audio.play().then(fadeIn).catch(() => { started = false; });
      btn.classList.add('visible');
    }

    function toggleMute() {
      muted = !muted;
      if (muted) {
        audio.volume = 0;
        iconOn.style.display  = 'none';
        iconOff.style.display = '';
        btn.style.opacity = '0.45';
      } else {
        fadeIn();
        iconOn.style.display  = '';
        iconOff.style.display = 'none';
        btn.style.opacity = '1';
      }
    }

    ['click', 'scroll', 'keydown', 'touchstart'].forEach(evt => {
      window.addEventListener(evt, startMusic, { once: true, passive: true });
    });

    btn.addEventListener('click', (e) => { e.stopPropagation(); toggleMute(); });
  })();
  </script>

</Layout>
